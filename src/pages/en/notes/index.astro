---
import type { MarkdownHeading } from 'astro'

import { getPageContent } from '@/lib/content-source'
import NotesView from '@/components/pages/NotesView.astro'
import { buildNoteTree, flattenNoteTree, getNotesCollectionEn } from '@/server'
import { getDescriptionFromMarkdown, renderContentMarkdown } from '@/utils/content-markdown'
import { getNoteCategoryGroups, getNotesWithoutCategory } from '@/utils/note-categories'

export const prerender = true

const notes = await getNotesCollectionEn()
const root = buildNoteTree(notes, 'Notes')
const flatTree = flattenNoteTree(root)
const categoryGroups = getNoteCategoryGroups(notes)
const uncategorizedRoot = buildNoteTree(getNotesWithoutCategory(notes), 'Notes')

let html: string | undefined
let headings: MarkdownHeading[] = []
let description = 'Browse all notes and nested notebooks.'

if (root.page) {
  const markdown = await getPageContent(root.page.source)
  const rendered = await renderContentMarkdown(markdown)
  html = rendered.html
  headings = rendered.headings
  description = getDescriptionFromMarkdown(markdown, root.page.title)
}

const title = root.page?.title || 'Notes'
const breadcrumbs = [{ title, href: '/en/notes' }]
---

<NotesView
  title={title}
  {description}
  basePath='/en/notes'
  currentPath=''
  rootTitle='NOTEBOOK'
  {flatTree}
  {breadcrumbs}
  childNodes={root.children}
  {categoryGroups}
  uncategorizedNodes={uncategorizedRoot.children}
  indexMode
  {headings}
  {html}
/>
